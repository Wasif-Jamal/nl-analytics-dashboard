# Environment configuration for the Natural Language Analytics Dashboard.
# Copy to .env and fill in real values. Loaded by app/config/env_config.py.

# ── LLM (Google GenAI / Gemini) ───────────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.0

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/superstore.db
CSV_PATH=data/database.csv

# ── SQL Agent ──────────────────────────────────────────────────────────────────
# Max self-correction attempts when generated SQL fails validation or execution.
SQL_RETRY_LIMIT=3
